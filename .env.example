APP_NAME=gerador-nfse-nacional-laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nfse
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# NFSe Nacional

# Ambiente: 2 = homologação, 1 = produção (tpAmb no XML)
NFSE_AMBIENTE=2
NFSE_BASE_URL=https://adn.producaorestrita.nfse.gov.br
NFSE_URL_EMISSAO=https://sefin.producaorestrita.nfse.gov.br/SefinNacional/nfse
NFSE_URL_CONSULTA=https://sefin.producaorestrita.nfse.gov.br/SefinNacional/consulta

# Série da nota (o próximo número DPS é obtido automaticamente pela tabela nfse_sequencia):
# Use 900 para Homologação (Padrão Nacional)
# Use 1, 2, etc. para Produção (Verificar com o contador)
NFSE_SERIE_DPS=900

# Certificado A1: .pfx para assinatura do XML e para mTLS (extração em tempo de execução)
NFSE_CERT_CAMINHO="storage/app/certificados/certificado.pfx"
NFSE_CERT_SENHA=senha_certificado

# Debug mTLS: true salva cert/key em storage/app para testar com curl
NFSE_DEBUG_MTLS=false

# Grava XML enviado em storage/logs/ quando true (útil para RNG9999 / suporte SEFIN)
NFSE_DEBUG_XML=false

#Dados do Prestador (Sua Empresa)
NFSE_EMPRESA_CNPJ=
NFSE_EMPRESA_IM=
NFSE_EMPRESA_RAZAO=
NFSE_EMPRESA_REGIME=
NFSE_EMPRESA_MUNICIPIO=
NFSE_EMPRESA_CNAE=
NFSE_EMPRESA_CTRIB_MUN=
NFSE_EMPRESA_OPTANTE_SIMPLES=true
NFSE_EMPRESA_LOGRADOURO=
NFSE_EMPRESA_NUMERO=

# Dados do cliente
NFSE_CLIENTE_DOCUMENTO=
NFSE_CLIENTE_TIPO_DOCUMENTO=CPF
NFSE_CLIENTE_NOME=
NFSE_CLIENTE_EMAIL=
NFSE_CLIENTE_TELEFONE=
NFSE_CLIENTE_CEP=
NFSE_CLIENTE_LOGRADOURO=
NFSE_CLIENTE_NUMERO=
NFSE_CLIENTE_BAIRRO=
NFSE_CLIENTE_MUNICIPIO=
NFSE_CLIENTE_UF=
NFSE_CLIENTE_IM=

# Dados do serviço
NFSE_SERVICO_CODIGO=01.01
NFSE_SERVICO_DESCRICAO=
NFSE_SERVICO_VALOR=50.00
NFSE_SERVICO_CTRIB_MUN=01.01
NFSE_SERVICO_ALIQUOTA_ISS=0.02
NFSE_SERVICO_ISS_RETIDO=false
NFSE_SERVICO_VALOR_ISS=1.00
